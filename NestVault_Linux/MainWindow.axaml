<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="NestVault_Linux.MainWindow"
        Title="NestVault"
        Icon="avares://NestVault_Linux/Assets/app.png"
        Width="1060" Height="700"
        MinWidth="860" MinHeight="520"
        Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}">

    <Grid ColumnDefinitions="200,*">

        <!-- Navigation Pane -->
        <Border Grid.Column="0"
                Background="{DynamicResource NavigationViewDefaultPaneBackground}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- App Title -->
                <Border DockPanel.Dock="Top" Padding="16,22,16,18">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="💾" FontSize="22"/>
                        <TextBlock Text="NestVault" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Separator -->
                <Border DockPanel.Dock="Top" Height="1" Margin="14,0"
                        Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

                <!-- Settings Footer -->
                <ListBox x:Name="FooterNav"
                         Classes="NavList"
                         DockPanel.Dock="Bottom"
                         SelectionChanged="FooterNav_SelectionChanged">
                    <ListBoxItem Tag="settings">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⚙" FontSize="14"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

                <!-- Footer separator -->
                <Border DockPanel.Dock="Bottom" Height="1" Margin="14,0"
                        Background="{DynamicResource SystemControlForegroundBaseLowBrush}"/>

                <!-- Main Nav -->
                <ListBox x:Name="MainNav"
                         Classes="NavList"
                         DockPanel.Dock="Top"
                         SelectionChanged="MainNav_SelectionChanged">
                    <ListBoxItem Tag="dashboard">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⌂" FontSize="14"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="backups">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⬡" FontSize="14"/>
                            <TextBlock Text="Backups" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="mybackups">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🛡" FontSize="14"/>
                            <TextBlock Text="My Backups" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem Tag="cleanup">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="🗑" FontSize="14"/>
                            <TextBlock Text="Cleanup" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>

            </DockPanel>
        </Border>

        <!-- Content Frame -->
        <ContentControl Grid.Column="1" x:Name="ContentFrame"/>

    </Grid>
</Window>
