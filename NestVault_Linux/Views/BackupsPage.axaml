<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NestVault_Linux.ViewModels"
             xmlns:models="using:NestVault_Linux.Models"
             x:Class="NestVault_Linux.Views.BackupsPage"
             x:DataType="vm:BackupsViewModel">

    <Grid ColumnDefinitions="240,1,220,1,*">

        <!-- Column 1: Backups list -->
        <DockPanel Grid.Column="0">
            <StackPanel DockPanel.Dock="Top" Spacing="8" Margin="12,12,12,8">
                <TextBlock Text="Backups" FontSize="16" FontWeight="Bold"/>
                <TextBox Text="{CompiledBinding SearchText}"
                         Watermark="Search…"/>
            </StackPanel>
            <ListBox ItemsSource="{CompiledBinding FilteredBackups}"
                     SelectedItem="{CompiledBinding SelectedBackup}"
                     Margin="4,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:BackupSummary">
                        <StackPanel Margin="4,4" Spacing="2">
                            <TextBlock Text="{CompiledBinding Label}" FontWeight="SemiBold"/>
                            <TextBlock Text="{CompiledBinding FormattedSize}"
                                       FontSize="11" Opacity="0.6"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Divider -->
        <Border Grid.Column="1" Classes="Divider"/>

        <!-- Column 2: Versions list -->
        <DockPanel Grid.Column="2">
            <TextBlock DockPanel.Dock="Top" Text="Versions" FontSize="14" FontWeight="SemiBold"
                       Margin="12,12,12,8"/>
            <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="2" Margin="0,0,0,4"
                         IsVisible="{CompiledBinding IsLoadingVersions}"/>
            <ListBox ItemsSource="{CompiledBinding Versions}"
                     SelectedItem="{CompiledBinding SelectedVersion}"
                     Margin="4,0">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:BackupVersion">
                        <StackPanel Margin="4,4" Spacing="2">
                            <TextBlock Text="{CompiledBinding VersionKey}" FontSize="12" FontFamily="monospace"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{CompiledBinding FileCount, StringFormat='{0} files'}"
                                           FontSize="11" Opacity="0.6"/>
                                <TextBlock Text="{CompiledBinding FormattedSize}"
                                           FontSize="11" Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Delete Version"
                                  Command="{CompiledBinding $parent[UserControl].((vm:BackupsViewModel)DataContext).DeleteVersionCommand}"
                                  CommandParameter="{CompiledBinding}"/>
                    </ContextMenu>
                </ListBox.ContextMenu>
            </ListBox>
        </DockPanel>

        <!-- Divider -->
        <Border Grid.Column="3" Classes="Divider"/>

        <!-- Column 3: Files DataGrid -->
        <DockPanel Grid.Column="4">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="12,12,12,8">
                <TextBlock Text="Files" FontSize="14" FontWeight="SemiBold"/>
                <TextBlock Text="{CompiledBinding Files.Count, StringFormat='({0})'}"
                           Opacity="0.6" VerticalAlignment="Center"/>
            </StackPanel>
            <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="2"
                         IsVisible="{CompiledBinding IsLoadingFiles}"/>
            <DataGrid ItemsSource="{CompiledBinding Files}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Path"    Binding="{Binding OriginalPath}" Width="*"/>
                    <DataGridTextColumn Header="Size"    Binding="{Binding FormattedSize}" Width="70"/>
                    <DataGridTextColumn Header="SHA256"  Binding="{Binding Sha256}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>

    </Grid>

</UserControl>
