<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="NestVault_Linux.Views.Controls.StatCard"
             x:Name="Root">

    <Border Classes="CardElevated">
        <StackPanel Spacing="6">
            <TextBlock Text="{Binding Icon, ElementName=Root}"
                       FontSize="22" Opacity="0.75"
                       IsVisible="{Binding Icon, ElementName=Root, Converter={StaticResource StringNotEmptyConverter}}"/>
            <TextBlock Text="{Binding Value, ElementName=Root}"
                       FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="{Binding Title, ElementName=Root}"
                       FontSize="13" FontWeight="SemiBold" Opacity="0.85"/>
            <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                       FontSize="11" Opacity="0.55"/>
        </StackPanel>
    </Border>

</UserControl>
