<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:NestVault_Linux.ViewModels"
        xmlns:services="using:NestVault_Linux.Services"
        x:Class="NestVault_Linux.Views.BackupRunnerDialog"
        x:DataType="vm:BackupRunnerViewModel"
        Title="Running Backup"
        Width="720" Height="540"
        MinWidth="500" MinHeight="380"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" Margin="20">

        <!-- Profile name + status -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
            <TextBlock Text="Backup:" VerticalAlignment="Center" Opacity="0.6"/>
            <TextBlock Text="{CompiledBinding ProfileName}" FontWeight="SemiBold" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Progress bar -->
        <ProgressBar Grid.Row="1" Value="{CompiledBinding Progress}" Minimum="0" Maximum="1"
                     Height="6" Margin="0,0,0,12"/>

        <!-- Stats row -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*">
            <Grid Grid.Row="0" ColumnDefinitions="*,*,*,*,*" Margin="0,0,0,8">
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="{CompiledBinding Stats.Total}"   FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Total" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="{CompiledBinding Stats.Uploaded}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Uploaded" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="{CompiledBinding Stats.Cached}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Cached" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="{CompiledBinding Stats.Registered}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="Registered" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <TextBlock Text="{CompiledBinding Stats.Errors}" FontSize="20" FontWeight="Bold"
                               Foreground="{CompiledBinding HasErrors, Converter={StaticResource BoolToRedBrushConverter}}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Errors" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Log -->
            <ScrollViewer Grid.Row="1" x:Name="LogScroller" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                <ItemsControl ItemsSource="{CompiledBinding Entries}" Margin="8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="services:BackupRunner+LogEntry">
                            <TextBlock Text="{CompiledBinding Text}"
                                       Foreground="{CompiledBinding Kind, Converter={StaticResource LogKindToColorBrushConverter}}"
                                       FontFamily="monospace" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Current file -->
        <TextBlock Grid.Row="3" Text="{CompiledBinding CurrentFile}"
                   FontFamily="monospace" FontSize="11" Opacity="0.6"
                   TextTrimming="CharacterEllipsis" Margin="0,8,0,0"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel"
                    Command="{CompiledBinding CancelCommand}"
                    IsEnabled="{CompiledBinding CanCancel}"/>
            <Button Content="Close"
                    IsEnabled="{CompiledBinding IsFinished}"
                    Click="Close_Click"/>
        </StackPanel>

    </Grid>

</Window>
