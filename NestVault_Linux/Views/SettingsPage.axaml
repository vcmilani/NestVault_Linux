<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NestVault_Linux.ViewModels"
             x:Class="NestVault_Linux.Views.SettingsPage"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer Padding="24">
        <StackPanel MaxWidth="620" Spacing="16">

            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" Margin="4,0"/>

            <TabControl>

                <!-- General Tab -->
                <TabItem Header="General">
                    <StackPanel Spacing="12" Margin="0,12">

                        <Border Classes="CardElevated">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Startup" Classes="SectionHeader" Margin="0,0,0,4"/>
                                <ToggleSwitch Content="Start NestVault when I log in"
                                             IsChecked="{CompiledBinding LaunchAtStartup}"/>
                            </StackPanel>
                        </Border>

                        <Border Classes="CardElevated">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Power &amp; Network" Classes="SectionHeader" Margin="0,0,0,4"/>
                                <ToggleSwitch Content="Pause scheduled backups on battery"
                                             IsChecked="{CompiledBinding PauseOnBattery}"/>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Minimum battery % to allow backup" Opacity="0.7" FontSize="12"/>
                                    <NumericUpDown Value="{CompiledBinding MinBatteryPercent}"
                                                   Minimum="0" Maximum="100"
                                                   IsEnabled="{CompiledBinding PauseOnBattery}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Classes="CardElevated">
                            <StackPanel Spacing="8">
                                <TextBlock Text="System Status" Classes="SectionHeader" Margin="0,0,0,4"/>
                                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto"
                                      ColumnSpacing="16" RowSpacing="8">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Power" Opacity="0.6" FontSize="12"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{CompiledBinding PowerStatusText}" FontSize="12"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Network" Opacity="0.6" FontSize="12"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{CompiledBinding NetworkType}" FontSize="12"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Network Available" Opacity="0.6" FontSize="12"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1"
                                               Text="{CompiledBinding IsNetworkAvailable}"
                                               Foreground="{CompiledBinding IsNetworkAvailable, Converter={StaticResource BoolToGreenRedColorConverter}}"
                                               FontSize="12"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </TabItem>

                <!-- Server Tab -->
                <TabItem Header="Server">
                    <StackPanel Spacing="12" Margin="0,12">

                        <Border Classes="CardElevated">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Connection" Classes="SectionHeader" Margin="0,0,0,4"/>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Server URL" Opacity="0.7" FontSize="12"/>
                                    <TextBox Text="{CompiledBinding ServerUrl}" PlaceholderText="http://..."/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="API Key" Opacity="0.7" FontSize="12"/>
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                        <TextBox Grid.Column="0"
                                                 Text="{CompiledBinding ApiKey}"
                                                 PasswordChar="{CompiledBinding ShowApiKey, Converter={StaticResource BoolNegateConverter}, ConverterParameter='•'}"
                                                 PlaceholderText="optional"/>
                                        <ToggleButton Grid.Column="1"
                                                      IsChecked="{CompiledBinding ShowApiKey}"
                                                      Content="👁"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="Test Connection"
                                            Command="{CompiledBinding TestConnectionCommand}"
                                            IsEnabled="{CompiledBinding !IsTestingConnection}"/>
                                </StackPanel>
                                <TextBlock Text="{CompiledBinding TestConnectionStatus}"
                                           Opacity="0.8" FontSize="12"
                                           IsVisible="{CompiledBinding TestConnectionStatus, Converter={StaticResource StringNotEmptyConverter}}"/>
                                <TextBlock Text="{CompiledBinding ServerVersion}"
                                           Opacity="0.55" FontSize="12"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </TabItem>

                <!-- Queue Schedule Tab -->
                <TabItem Header="Queue Schedule">
                    <StackPanel Spacing="12" Margin="0,12">

                        <Border Classes="CardElevated">
                            <StackPanel Spacing="12" DataContext="{CompiledBinding QueueSchedule}">
                                <TextBlock Text="Scheduled Queue Run" Classes="SectionHeader" Margin="0,0,0,4"/>
                                <TextBlock Opacity="0.65" TextWrapping="Wrap" FontSize="12"
                                           Text="Run all enabled profiles in sequence on a schedule."/>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Frequency" Opacity="0.7" FontSize="12"/>
                                    <ComboBox SelectedIndex="{CompiledBinding FrequencyIndex}" MinWidth="160">
                                        <ComboBoxItem Content="Off"/>
                                        <ComboBoxItem Content="Hourly"/>
                                        <ComboBoxItem Content="Daily"/>
                                        <ComboBoxItem Content="Weekly"/>
                                        <ComboBoxItem Content="Custom"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Spacing="10" IsVisible="{CompiledBinding Enabled}">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Hour" Opacity="0.7" FontSize="12"/>
                                        <NumericUpDown Value="{CompiledBinding Hour}" Minimum="0" Maximum="23"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Minute" Opacity="0.7" FontSize="12"/>
                                        <NumericUpDown Value="{CompiledBinding Minute}" Minimum="0" Maximum="59"/>
                                    </StackPanel>
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="Custom interval (minutes)" Opacity="0.7" FontSize="12"/>
                                        <NumericUpDown Value="{CompiledBinding CustomMinutes}" Minimum="1" Maximum="10080"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </TabItem>

                <!-- About Tab -->
                <TabItem Header="About">
                    <Border Classes="CardElevated" Margin="0,12">
                        <StackPanel Spacing="12" HorizontalAlignment="Center">
                            <TextBlock Text="💾" FontSize="48" HorizontalAlignment="Center"/>
                            <TextBlock Text="NestVault" FontSize="28" FontWeight="Bold"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="{CompiledBinding AppVersion, StringFormat='v{0}'}"
                                       Opacity="0.6" HorizontalAlignment="Center"/>
                            <TextBlock Text="Self-hosted backup manager"
                                       Opacity="0.7" HorizontalAlignment="Center"/>
                            <TextBlock Text="Linux / macOS — Avalonia UI 12 · .NET 10"
                                       Opacity="0.45" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </TabItem>

            </TabControl>

            <!-- Save -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,0">
                <Button Content="Save Settings"
                        Command="{CompiledBinding SaveCommand}"
                        IsEnabled="{CompiledBinding IsDirty}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
