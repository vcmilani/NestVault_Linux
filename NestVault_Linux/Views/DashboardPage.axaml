<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NestVault_Linux.ViewModels"
             xmlns:models="using:NestVault_Linux.Models"
             xmlns:controls="using:NestVault_Linux.Views.Controls"
             x:Class="NestVault_Linux.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel">

    <ScrollViewer Padding="20,20,20,24">
        <StackPanel Spacing="12">

            <!-- Header -->
            <Grid ColumnDefinitions="*,Auto" Margin="4,0,4,4">
                <TextBlock Grid.Column="0"
                           Text="Dashboard"
                           FontSize="24" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        ToolTip.Tip="Reload data"
                        Command="{CompiledBinding ReloadCommand}"
                        IsEnabled="{CompiledBinding !IsLoading}">
                    <TextBlock Text="↻" FontSize="16"/>
                </Button>
            </Grid>

            <!-- Disconnected Banner -->
            <Border IsVisible="{CompiledBinding !IsConnected}"
                    Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                    CornerRadius="8" Padding="14,10" Margin="4,0">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="⚠" FontSize="16" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Not connected to server" FontWeight="SemiBold"/>
                        <TextBlock Text="{CompiledBinding ConnectionError}"
                                   Opacity="0.7" FontSize="12"
                                   IsVisible="{CompiledBinding ConnectionError, Converter={StaticResource StringNotEmptyConverter}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Stats Cards -->
            <Grid ColumnDefinitions="*,*,*,*">
                <controls:StatCard Grid.Column="0"
                                   Icon="📦"
                                   Title="Backups"
                                   Value="{CompiledBinding Stats.TotalBackups, StringFormat=\{0\}}"
                                   Subtitle="labels"/>
                <controls:StatCard Grid.Column="1"
                                   Icon="🗂"
                                   Title="Versions"
                                   Value="{CompiledBinding Stats.TotalVersions, StringFormat=\{0\}}"
                                   Subtitle="snapshots"/>
                <controls:StatCard Grid.Column="2"
                                   Icon="📄"
                                   Title="Files"
                                   Value="{CompiledBinding Stats.TotalFiles, StringFormat=\{0\}}"
                                   Subtitle="stored"/>
                <controls:StatCard Grid.Column="3"
                                   Icon="💽"
                                   Title="Total Size"
                                   Value="{CompiledBinding Stats.FormattedSize}"
                                   Subtitle="on server"/>
            </Grid>

            <!-- Server Status -->
            <Border Classes="CardElevated" Margin="4,0">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Column="0"
                               Text="🖧" FontSize="22"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="NestVault Server" FontWeight="SemiBold" FontSize="14"/>
                        <TextBlock Text="{CompiledBinding ServerVersion, StringFormat='v{0}'}"
                                   FontSize="12" Opacity="0.55"
                                   IsVisible="{CompiledBinding IsConnected}"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Border Classes="Pill Green" IsVisible="{CompiledBinding IsConnected}">
                            <TextBlock Text="Connected" FontSize="11" Foreground="#34C759"/>
                        </Border>
                        <Border Classes="Pill Red" IsVisible="{CompiledBinding !IsConnected}">
                            <TextBlock Text="Disconnected" FontSize="11" Foreground="#FF453A"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Recent Backups -->
            <TextBlock Text="Recent Backups" Classes="SectionHeader" Margin="8,4,8,0"/>
            <Border Classes="CardElevated" Padding="0" Margin="4,0">
                <ListBox ItemsSource="{CompiledBinding Backups}"
                         MaxHeight="300"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="models:BackupSummary">
                            <Grid ColumnDefinitions="*,Auto" Margin="12,8">
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{CompiledBinding Label}"
                                               FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Text="{CompiledBinding ClientName}"
                                               FontSize="11" Opacity="0.55"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{CompiledBinding VersionCount, StringFormat='{}{0} ver'}"
                                               FontSize="11" Opacity="0.5" VerticalAlignment="Center"/>
                                    <Border Classes="Pill Gray">
                                        <TextBlock Text="{CompiledBinding FormattedSize}" FontSize="11"/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <!-- How It Works -->
            <Expander Header="How It Works" Margin="4,4">
                <StackPanel Spacing="8" Margin="0,8">
                    <TextBlock TextWrapping="Wrap" Opacity="0.8"
                               Text="NestVault backs up your folders to a self-hosted server. Each run creates a new version of your backup, allowing you to restore any point in time."/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.8"
                               Text="Smart Skip detects when nothing has changed and records a reference to the last version instead of uploading duplicate files."/>
                    <TextBlock TextWrapping="Wrap" Opacity="0.8"
                               Text="The scheduler automatically runs backups based on your configured frequency, respecting battery and network conditions."/>
                </StackPanel>
            </Expander>

        </StackPanel>
    </ScrollViewer>

</UserControl>
